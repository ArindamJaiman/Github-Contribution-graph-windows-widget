{
  "name": "github-contribution-widget",
  "version": "1.0.0",
  "description": "A lightweight desktop widget that displays your GitHub contribution graph",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build:installer": "electron-builder --win nsis"
  },
  "author": "GitHub Contribution Widget",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "axios": "^1.6.5"
  },
  "build": {
    "appId": "com.github.contribution-widget",
    "productName": "GitHub Contribution Widget",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "portable": {
      "artifactName": "GitHubContributionWidget.exe"
    },
    "files": [
      "src/**/*",
      "config.json",
      "data.json",
      "assets/**/*"
    ]
  }
}
