{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "github-contribution-widget",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "GitHub Contribution Widget",
        "width": 880,
        "height": 240,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "skipTaskbar": true,
        "alwaysOnTop": false,
        "shadow": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
